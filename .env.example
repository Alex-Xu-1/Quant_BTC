# ============================================
# BTC 机器学习量化策略 - 环境变量配置模板
# ============================================
# 使用方法：复制此文件为 .env，填入实际的 API 密钥
# cp .env.example .env

# Binance 交易所 API 配置（实盘交易时需要）
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET=your_binance_secret_here

# 交易模式：backtest（回测）/ paper（模拟盘）/ live（实盘）
TRADING_MODE=backtest

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
